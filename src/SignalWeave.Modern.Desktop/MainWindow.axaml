<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="SignalWeave.Modern.Desktop.MainWindow"
        Title="SignalWeave Modern"
        Width="1280"
        Height="840"
        MinWidth="1080"
        MinHeight="720"
        Background="#F4F0E8">
    <Window.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FFFDF8" />
            <Setter Property="BorderBrush" Value="#D8CFC2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#2A2722" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#615A52" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto"
          RowSpacing="16"
          Margin="24">
        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="24">
            <StackPanel Spacing="6">
                <TextBlock Text="SignalWeave Modern"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="#1F1B16" />
                <TextBlock Text="A second product line with a new workflow, sharing the same training engine and parsers as the Classic desktop."
                           Classes="muted"
                           TextWrapping="Wrap"
                           MaxWidth="760" />
            </StackPanel>

            <Border Grid.Column="1"
                    Classes="card"
                    Padding="14,10">
                <StackPanel Spacing="2">
                    <TextBlock Text="Release line"
                               FontWeight="SemiBold" />
                    <TextBlock Text="modern-vX.Y.Z"
                               Classes="muted" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1"
              ColumnDefinitions="1.3*,1*"
              ColumnSpacing="16">
            <Border Classes="card">
                <Grid RowDefinitions="Auto,Auto,*"
                      RowSpacing="12">
                    <TextBlock Text="Workflow Direction"
                               Classes="section-title" />
                    <TextBlock Grid.Row="1"
                               Classes="muted"
                               TextWrapping="Wrap"
                               Text="This app is the place to build a new interaction model around the shared SignalWeave engine: project-first workflow, guided training setup, and analysis-first review surfaces." />
                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="12"
                          RowSpacing="12">
                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Shared engine" FontWeight="SemiBold" />
                                <TextBlock x:Name="EngineSummaryText"
                                           Classes="muted"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1"
                                Classes="card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Immediate goals" FontWeight="SemiBold" />
                                <TextBlock Classes="muted" TextWrapping="Wrap"
                                           Text="Separate the workflow from the BasicProp shell while preserving the same parser, trainer, weights, testing, clustering, and export logic." />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1"
                                Classes="card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Sample: XOR" FontWeight="SemiBold" />
                                <TextBlock x:Name="XorSummaryText"
                                           Classes="muted"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Classes="card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Sample: Echo SRN" FontWeight="SemiBold" />
                                <TextBlock x:Name="SrnSummaryText"
                                           Classes="muted"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1"
                        Spacing="16">
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Product lines"
                                   Classes="section-title" />
                        <TextBlock Classes="muted"
                                   TextWrapping="Wrap"
                                   Text="Classic keeps the BasicProp-style workflow. Modern is free to evolve a different UI while reusing the same engine and general logic." />
                    </StackPanel>
                </Border>

                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Release strategy"
                                   Classes="section-title" />
                        <TextBlock Classes="muted"
                                   TextWrapping="Wrap"
                                   Text="Classic releases use classic-vX.Y.Z tags. Modern releases use modern-vX.Y.Z tags. Each line publishes its own binaries and release notes." />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Classes="card"
                Padding="14,10">
            <TextBlock Classes="muted"
                       TextWrapping="Wrap"
                       Text="Current state: the Classic desktop remains the parity-first product. The Modern desktop is now a separate app shell in the same repo, ready for a new workflow without forking the engine." />
        </Border>
    </Grid>
</Window>
