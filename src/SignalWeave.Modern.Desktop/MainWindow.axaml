<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="SignalWeave.Modern.Desktop.MainWindow"
        Title="SignalWeave Modern"
        Width="1480"
        Height="920"
        MinWidth="1220"
        MinHeight="760"
        Background="#F4F0E8">
    <Window.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FFFDF9" />
            <Setter Property="BorderBrush" Value="#D7CCBD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style Selector="TextBlock.title">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#211D19" />
        </Style>
        <Style Selector="TextBlock.section">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#2D2924" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#6A6258" />
        </Style>
        <Style Selector="Button.action">
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="Padding" Value="14,10" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Project" Click="NewProject_Click" />
                <MenuItem Header="_Load Project" Click="LoadProject_Click" />
                <MenuItem Header="_Save Project" Click="SaveProject_Click" />
                <MenuItem Header="Save Project _As" Click="SaveProjectAs_Click" />
                <Separator />
                <MenuItem Header="E_xit" Click="Exit_Click" />
            </MenuItem>
        </Menu>

        <Grid Margin="20"
              RowDefinitions="Auto,*,220"
              ColumnDefinitions="1.8*,1*"
              RowSpacing="18"
              ColumnSpacing="18">
            <Border Classes="card"
                    Grid.ColumnSpan="2"
                    Padding="18,14">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="18">
                    <StackPanel Spacing="4">
                        <TextBlock Text="SignalWeave Modern"
                                   Classes="title" />
                        <TextBlock x:Name="ProjectPathTextBlock"
                                   Classes="muted"
                                   Text="Project file: unsaved project" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                Spacing="4">
                        <TextBlock Text="Unified project workflow"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right" />
                        <TextBlock x:Name="WorkspaceStatusTextBlock"
                                   Classes="muted"
                                   HorizontalAlignment="Right"
                                   Text="Ready." />
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl Grid.Row="1"
                        Margin="0"
                        TabStripPlacement="Top">
                <TabItem Header="Patterns">
                    <Border Classes="card"
                            Padding="0">
                        <Grid RowDefinitions="Auto,*"
                              RowSpacing="12"
                              Margin="16">
                            <TextBlock Classes="muted"
                                       TextWrapping="Wrap"
                                       Text="Patterns are edited directly in the project. Saving the project persists the network settings, current weights, training-cycle count, and control-panel state in one file." />

                            <TextBox Grid.Row="1"
                                     x:Name="PatternEditorTextBox"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     FontFamily="Cascadia Mono, Consolas, monospace" />
                        </Grid>
                    </Border>
                </TabItem>

                <TabItem Header="Results">
                    <Border Classes="card"
                            Padding="0">
                        <Grid RowDefinitions="Auto,200,*"
                              RowSpacing="14"
                              Margin="16">
                            <Grid ColumnDefinitions="2.2*,1*"
                                  ColumnSpacing="16">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Project summary"
                                               Classes="section" />
                                    <TextBlock x:Name="ProjectSummaryTextBlock"
                                               Classes="muted"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Spacing="6">
                                    <TextBlock Text="Weights"
                                               Classes="section" />
                                    <TextBlock x:Name="WeightsSummaryTextBlock"
                                               Classes="muted"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1"
                                    BorderBrush="#D7CCBD"
                                    BorderThickness="1"
                                    Padding="10">
                                <Grid RowDefinitions="Auto,*"
                                      RowSpacing="8">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="12">
                                        <TextBlock Text="Training history"
                                                   Classes="section" />
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    Spacing="8">
                                            <TextBlock Text="Display"
                                                       VerticalAlignment="Center"
                                                       Classes="muted" />
                                            <ComboBox x:Name="PlotModeComboBox"
                                                      Width="120"
                                                      SelectionChanged="PlotModeComboBox_SelectionChanged">
                                                <ComboBoxItem Content="Line" />
                                                <ComboBoxItem Content="Dots" />
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <Canvas Grid.Row="1"
                                            x:Name="ErrorPlotCanvas"
                                            MinHeight="150"
                                            Background="#FFF9F1" />
                                </Grid>
                            </Border>

                            <TextBox Grid.Row="2"
                                     x:Name="ResultsTextBox"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     FontFamily="Cascadia Mono, Consolas, monospace" />
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Classes="card"
                    Padding="0">
                <TabControl x:Name="ControlTabs"
                            Margin="0"
                            TabStripPlacement="Top">
                    <TabItem Header="Network">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="16"
                                  ColumnDefinitions="Auto,*"
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                  ColumnSpacing="12"
                                  RowSpacing="10">
                                <TextBlock Text="Project name" VerticalAlignment="Center" />
                                <TextBox x:Name="ProjectNameTextBox" Grid.Column="1" />

                                <TextBlock Grid.Row="1" Text="Network type" VerticalAlignment="Center" />
                                <ComboBox x:Name="NetworkKindComboBox"
                                          Grid.Row="1"
                                          Grid.Column="1"
                                          SelectedIndex="0"
                                          SelectionChanged="NetworkKindComboBox_SelectionChanged">
                                    <ComboBoxItem Content="FeedForward" />
                                    <ComboBoxItem Content="SimpleRecurrent" />
                                </ComboBox>

                                <TextBlock Grid.Row="2" Text="Inputs" VerticalAlignment="Center" />
                                <TextBox x:Name="InputUnitsTextBox" Grid.Row="2" Grid.Column="1" />

                                <TextBlock Grid.Row="3" Text="Hidden layer 1" VerticalAlignment="Center" />
                                <TextBox x:Name="HiddenUnitsTextBox" Grid.Row="3" Grid.Column="1" />

                                <TextBlock Grid.Row="4" Text="Hidden layer 2" VerticalAlignment="Center" />
                                <TextBox x:Name="SecondHiddenUnitsTextBox" Grid.Row="4" Grid.Column="1" />

                                <TextBlock Grid.Row="5" Text="Outputs" VerticalAlignment="Center" />
                                <TextBox x:Name="OutputUnitsTextBox" Grid.Row="5" Grid.Column="1" />

                                <TextBlock Grid.Row="6" Text="Biases" VerticalAlignment="Center" />
                                <StackPanel Grid.Row="6"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="12">
                                    <CheckBox x:Name="InputBiasCheckBox" Content="Input" />
                                    <CheckBox x:Name="HiddenBiasCheckBox" Content="Hidden 1" />
                                    <CheckBox x:Name="SecondHiddenBiasCheckBox" Content="Hidden 2" />
                                </StackPanel>

                                <TextBlock Grid.Row="7" Text="Learning rate" VerticalAlignment="Center" />
                                <ComboBox x:Name="LearningRateComboBox"
                                          Grid.Row="7"
                                          Grid.Column="1"
                                          IsEditable="True" />

                                <TextBlock Grid.Row="8" Text="Momentum" VerticalAlignment="Center" />
                                <ComboBox x:Name="MomentumComboBox"
                                          Grid.Row="8"
                                          Grid.Column="1"
                                          IsEditable="True" />

                                <TextBlock Grid.Row="9" Text="Weight range" VerticalAlignment="Center" />
                                <ComboBox x:Name="WeightRangeComboBox"
                                          Grid.Row="9"
                                          Grid.Column="1"
                                          IsEditable="True" />

                                <TextBlock Grid.Row="10" Text="Error threshold" VerticalAlignment="Center" />
                                <TextBox x:Name="ErrorThresholdTextBox" Grid.Row="10" Grid.Column="1" />

                                <TextBlock Grid.Row="11" Text="Current cycles" VerticalAlignment="Center" />
                                <TextBlock x:Name="CompletedCyclesTextBlock"
                                           Grid.Row="11"
                                           Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Classes="muted" />
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Control">
                        <Grid Margin="16"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,*"
                              RowSpacing="14">
                            <Grid ColumnDefinitions="Auto,*"
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                  ColumnSpacing="12"
                                  RowSpacing="10">
                                <TextBlock Text="Learning steps" VerticalAlignment="Center" />
                                <ComboBox x:Name="LearningStepsComboBox"
                                          Grid.Column="1"
                                          IsEditable="True" />

                                <TextBlock Grid.Row="1" Text="Pattern" VerticalAlignment="Center" />
                                <ComboBox x:Name="PatternSelectorComboBox"
                                          Grid.Row="1"
                                          Grid.Column="1" />

                                <TextBlock Grid.Row="2" Text="Training mode" VerticalAlignment="Center" />
                                <CheckBox x:Name="BatchUpdateCheckBox"
                                          Grid.Row="2"
                                          Grid.Column="1"
                                          Content="Batch update" />

                                <TextBlock Grid.Row="3" Text="Error function" VerticalAlignment="Center" />
                                <CheckBox x:Name="CrossEntropyCheckBox"
                                          Grid.Row="3"
                                          Grid.Column="1"
                                          Content="Cross entropy" />

                                <TextBlock Grid.Row="4" Text="Plot mode" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="4"
                                           Grid.Column="1"
                                           Classes="muted"
                                           Text="Use the display chooser above the history chart." />
                            </Grid>

                            <UniformGrid Grid.Row="1"
                                         Columns="2"
                                         Rows="2"
                                         ColumnSpacing="10"
                                         RowSpacing="10">
                                <Button x:Name="ResetButton"
                                        Classes="action"
                                        Content="Reset"
                                        Click="Reset_Click" />
                                <Button x:Name="TrainButton"
                                        Classes="action"
                                        Content="Train"
                                        Click="Train_Click" />
                                <Button x:Name="TestOneButton"
                                        Classes="action"
                                        Content="Test One"
                                        Click="TestOne_Click" />
                                <Button x:Name="TestAllButton"
                                        Classes="action"
                                        Content="Test All"
                                        Click="TestAll_Click" />
                            </UniformGrid>

                            <Border Grid.Row="2"
                                    BorderBrush="#D7CCBD"
                                    BorderThickness="1"
                                    Padding="12">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="8">
                                        <TextBlock Text="Progress"
                                                   FontWeight="SemiBold" />
                                        <TextBlock x:Name="ProgressLabelTextBlock"
                                                   Grid.Column="1"
                                                   Classes="muted"
                                                   Text="Idle" />
                                    </Grid>
                                    <ProgressBar x:Name="TrainingProgressBar"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="0"
                                                 Height="14" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="3"
                                    BorderBrush="#D7CCBD"
                                    BorderThickness="1"
                                    Padding="12">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Latest run"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="LatestRunSummaryTextBlock"
                                               Classes="muted"
                                               TextWrapping="Wrap"
                                               Text="No run executed yet." />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="4"
                                    BorderBrush="#D7CCBD"
                                    BorderThickness="1"
                                    Padding="12">
                                <TextBlock x:Name="ProjectStateTextBlock"
                                           Classes="muted"
                                           TextWrapping="Wrap"
                                           Text="Save the project to persist the current network settings, weights, and control-panel state." />
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <Border Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Classes="card"
                    Padding="0">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="10"
                      Margin="16">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <TextBlock Text="Console"
                                   Classes="section" />
                        <Button Grid.Column="1"
                                Content="Clear"
                                Click="ClearConsole_Click" />
                    </Grid>

                    <TextBox Grid.Row="1"
                             x:Name="ConsoleTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
