<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:SignalWeave.Desktop.ViewModels"
        xmlns:shapes="clr-namespace:Avalonia.Controls.Shapes;assembly=Avalonia.Controls"
        mc:Ignorable="d"
        x:Class="SignalWeave.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SignalWeave: A Simple Neural Network Simulator. Version 1.0"
        Width="1360"
        Height="900"
        MinWidth="1180"
        MinHeight="780"
        Background="#D9D9D9">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.group">
            <Setter Property="BorderBrush" Value="#B8C7D6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#E6E6E6" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="TextBox.editor">
            <Setter Property="FontFamily" Value="Courier New" />
            <Setter Property="Background" Value="#F2F2F2" />
            <Setter Property="BorderBrush" Value="#B8C7D6" />
        </Style>
        <Style Selector="Button.panel">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Background" Value="#DCE4EC" />
            <Setter Property="BorderBrush" Value="#9FB4C9" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TextBlock.group-header">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#3A3A3A" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
    </Window.Styles>

    <DockPanel Margin="6">
        <Menu DockPanel.Dock="Top"
              Margin="0,0,0,4"
              Background="#ECECEC">
            <MenuItem Header="_Network">
                <MenuItem Header="_Configure Network" Click="ConfigureNetwork_Click" />
                <MenuItem Header="_Load Network" Click="LoadNetwork_Click" />
                <MenuItem Header="_Save Network" Click="SaveNetwork_Click" />
            </MenuItem>
            <MenuItem Header="_Weights">
                <MenuItem Header="_Show Weights" Click="ShowWeightsWindow_Click" />
                <MenuItem Header="_Load Weights (FF)" Click="LoadFeedForwardWeights_Click" />
                <MenuItem Header="Load Weights (_SRN)" Click="LoadSrnWeights_Click" />
                <MenuItem Header="_Save Weights" Click="SaveWeights_Click" />
            </MenuItem>
            <MenuItem Header="_Patterns">
                <MenuItem Header="_Show Patterns and Outputs" Click="ShowPatternsWindow_Click" />
                <MenuItem Header="_Load Patterns" Click="LoadPatterns_Click" />
            </MenuItem>
            <MenuItem Header="_Utilities">
                <MenuItem Header="_3D Plotting" Click="Show3DPlotWindow_Click" />
                <MenuItem Header="_Time Series Plot" Click="ShowTimeSeriesPlotWindow_Click" />
                <MenuItem Header="_Export hidden units activations" Command="{Binding ExportHiddenActivationsCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_Open SignalWeave repository" Click="OpenRepository_Click" />
            </MenuItem>
        </Menu>

        <Grid RowDefinitions="*,170"
              RowSpacing="8">
            <Grid ColumnDefinitions="*,258"
                  ColumnSpacing="8">
                <Border Classes="group">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Classes="group-header"
                                   Text="Network" />
                        <Border Grid.Row="1"
                                Background="#F2F2F2"
                                BorderBrush="#B8C7D6"
                                BorderThickness="1"
                                Padding="6">
                            <Grid RowDefinitions="*,Auto">
                                <Canvas x:Name="NetworkDiagramCanvas"
                                        Width="610"
                                        Height="360"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />

                                <StackPanel Grid.Row="1"
                                            Margin="0,8,0,0"
                                            Spacing="4"
                                            HorizontalAlignment="Center">
                                    <Grid ColumnDefinitions="Auto,44,44,44,44,Auto"
                                          ColumnSpacing="8"
                                          HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding WeightLegendLeftLabel}" />
                                        <TextBlock Grid.Column="1"
                                                   HorizontalAlignment="Center"
                                                   Text="{Binding WeightLegendMidLeftLabel}" />
                                        <TextBlock Grid.Column="2"
                                                   HorizontalAlignment="Center"
                                                   Text="{Binding WeightLegendZeroLabel}" />
                                        <TextBlock Grid.Column="3"
                                                   HorizontalAlignment="Center"
                                                   Text="{Binding WeightLegendMidRightLabel}" />
                                        <TextBlock Grid.Column="4"
                                                   HorizontalAlignment="Center"
                                                   Text="{Binding WeightLegendRightLabel}" />
                                    </Grid>
                                    <Canvas Width="250"
                                            Height="24"
                                            HorizontalAlignment="Center">
                                        <shapes:Line StartPoint="25,11"
                                                     EndPoint="225,11"
                                                     Stroke="#7A7A7A"
                                                     StrokeThickness="2" />
                                        <shapes:Line StartPoint="25,3"
                                                     EndPoint="25,19"
                                                     Stroke="#FF2020"
                                                     StrokeThickness="4" />
                                        <shapes:Line StartPoint="75,5"
                                                     EndPoint="75,17"
                                                     Stroke="#7A7A7A"
                                                     StrokeThickness="2" />
                                        <shapes:Line StartPoint="125,1"
                                                     EndPoint="125,21"
                                                     Stroke="#595959"
                                                     StrokeThickness="2" />
                                        <shapes:Line StartPoint="175,5"
                                                     EndPoint="175,17"
                                                     Stroke="#7A7A7A"
                                                     StrokeThickness="2" />
                                        <shapes:Line StartPoint="225,3"
                                                     EndPoint="225,19"
                                                     Stroke="#1FCB1F"
                                                     StrokeThickness="4" />
                                    </Canvas>
                                    <TextBlock Text="Weight value"
                                               HorizontalAlignment="Center"
                                               Foreground="#676767" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Classes="group">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Classes="group-header"
                                   Text="Control panel" />

                        <Grid Grid.Row="1"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              ColumnDefinitions="*,90"
                              RowSpacing="8"
                              ColumnSpacing="8"
                              Margin="2,2,2,0">
                            <TextBlock Text="Learning rate"
                                       VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding LearningRateOptions}"
                                      SelectedItem="{Binding SelectedLearningRate, Mode=TwoWay}" />

                            <TextBlock Grid.Row="1"
                                       Text="Momentum"
                                       VerticalAlignment="Center" />
                            <ComboBox Grid.Row="1"
                                      Grid.Column="1"
                                      ItemsSource="{Binding MomentumOptions}"
                                      SelectedItem="{Binding SelectedMomentum, Mode=TwoWay}" />

                            <TextBlock Grid.Row="2"
                                       Text="Learning steps"
                                       VerticalAlignment="Center" />
                            <ComboBox Grid.Row="2"
                                      Grid.Column="1"
                                      ItemsSource="{Binding LearningStepOptions}"
                                      SelectedItem="{Binding SelectedLearningSteps, Mode=TwoWay}" />

                            <TextBlock Grid.Row="3"
                                       Text="Weight range"
                                       VerticalAlignment="Center" />
                            <ComboBox Grid.Row="3"
                                      Grid.Column="1"
                                      ItemsSource="{Binding WeightRangeOptions}"
                                      SelectedItem="{Binding SelectedWeightRange, Mode=TwoWay}" />

                            <CheckBox Grid.Row="4"
                                      Content="Batch Update"
                                      IsChecked="{Binding BatchUpdate, Mode=TwoWay}" />
                            <CheckBox Grid.Row="4"
                                      Grid.Column="1"
                                      Content="X-entropy"
                                      IsChecked="{Binding CrossEntropy, Mode=TwoWay}" />

                            <Button Grid.Row="5"
                                    Classes="panel"
                                    Content="Reset"
                                    Command="{Binding ResetNetworkCommand}" />
                            <Button Grid.Row="5"
                                    Grid.Column="1"
                                    Classes="panel"
                                    Content="{Binding TrainButtonLabel}"
                                    Command="{Binding TrainCommand}" />

                            <TextBlock Grid.Row="6"
                                       Text="Progress"
                                       VerticalAlignment="Center" />
                            <Grid Grid.Row="6"
                                  Grid.Column="1">
                                <ProgressBar Minimum="0"
                                             Maximum="{Binding ProgressMaximum}"
                                             Value="{Binding ProgressValue}"
                                             Height="24"
                                             Foreground="#6689AF"
                                             Background="#EDF1F5"
                                             BorderBrush="#9FB0C0"
                                             BorderThickness="1" />
                                <TextBlock Text="{Binding ProgressLabel}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#5E7FA3"
                                           FontWeight="SemiBold" />
                            </Grid>

                            <TextBlock Grid.Row="7"
                                       Text="Pattern"
                                       VerticalAlignment="Center" />
                            <ComboBox Grid.Row="7"
                                      Grid.Column="1"
                                      ItemsSource="{Binding PatternOptions}"
                                      SelectedItem="{Binding SelectedPattern, Mode=TwoWay}" />

                            <Button Grid.Row="8"
                                    Grid.ColumnSpan="2"
                                    Classes="panel"
                                    Content="Test one"
                                    Command="{Binding TestOneCommand}"
                                    IsEnabled="{Binding CanTestOne}" />
                            <Button Grid.Row="9"
                                    Grid.ColumnSpan="2"
                                    Classes="panel"
                                    Content="Test all"
                                    Command="{Binding TestAllCommand}" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="1"
                  ColumnDefinitions="*,258"
                  ColumnSpacing="8">
                <Border Classes="group">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Classes="group-header"
                                   Text="Console" />
                        <TextBox Grid.Row="1"
                                 Classes="editor"
                                 Text="{Binding ConsoleText}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Classes="group">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Classes="group-header"
                                   Text="Error progress" />
                        <Border Grid.Row="1"
                                Background="#F7F7F7"
                                BorderBrush="#B8C7D6"
                                BorderThickness="1"
                                Padding="8">
                            <Grid RowDefinitions="Auto,*"
                                  ColumnDefinitions="Auto,*">
                                <TextBlock Text="{Binding ErrorPlotTopLabel}"
                                           Foreground="#5E5E5E"
                                           Margin="0,0,4,0" />
                                <Canvas Width="240"
                                        Height="132"
                                        Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <shapes:Line StartPoint="24,8"
                                                 EndPoint="24,116"
                                                 Stroke="#5A5A5A"
                                                 StrokeThickness="1.5" />
                                    <shapes:Line StartPoint="24,116"
                                                 EndPoint="250,116"
                                                 Stroke="#5A5A5A"
                                                 StrokeThickness="1.5" />
                                    <shapes:Line StartPoint="69,112"
                                                 EndPoint="69,120"
                                                 Stroke="#5A5A5A"
                                                 StrokeThickness="1.2" />
                                    <shapes:Line StartPoint="114,112"
                                                 EndPoint="114,120"
                                                 Stroke="#5A5A5A"
                                                 StrokeThickness="1.2" />
                                    <shapes:Line StartPoint="159,112"
                                                 EndPoint="159,120"
                                                 Stroke="#5A5A5A"
                                                 StrokeThickness="1.2" />
                                    <shapes:Line StartPoint="204,112"
                                                 EndPoint="204,120"
                                                 Stroke="#5A5A5A"
                                                 StrokeThickness="1.2" />
                                    <shapes:Polyline Points="{Binding ErrorProgressPoints}"
                                                     Stroke="#4E7396"
                                                     StrokeThickness="2" />
                                    <TextBlock Canvas.Left="4"
                                               Canvas.Top="116"
                                               Text="0"
                                               Foreground="#5E5E5E" />
                                    <TextBlock Canvas.Left="214"
                                               Canvas.Top="116"
                                               Text="{Binding ErrorPlotBottomRightLabel}"
                                               Foreground="#5E5E5E" />
                                </Canvas>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
