<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:SignalWeave.Desktop.ViewModels"
        xmlns:shapes="clr-namespace:Avalonia.Controls.Shapes;assembly=Avalonia.Controls"
        mc:Ignorable="d"
        x:Class="SignalWeave.Desktop.Views.WeightDisplayWindow"
        x:DataType="vm:WeightDisplayWindowViewModel"
        Width="960"
        Height="640"
        MinWidth="560"
        MinHeight="420"
        Background="#D5D5D5"
        Title="{Binding WindowTitle}">

    <Design.DataContext>
        <vm:WeightDisplayWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto"
          Margin="0">
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Canvas Width="{Binding CanvasWidth}"
                    Height="{Binding CanvasHeight}"
                    Background="#D5D5D5">
                <ItemsControl ItemsSource="{Binding WeightGlyphs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:WeightGlyphItem">
                            <Canvas>
                                <Border Width="{Binding CellWidth}"
                                        Height="{Binding CellHeight}"
                                        Background="{Binding CellFill}"
                                        Canvas.Left="{Binding X}"
                                        Canvas.Top="{Binding Y}" />
                                <shapes:Ellipse Width="{Binding EllipseWidth}"
                                                Height="{Binding EllipseHeight}"
                                                Fill="{Binding Fill}"
                                                Canvas.Left="{Binding EllipseX}"
                                                Canvas.Top="{Binding EllipseY}">
                                    <ToolTip.Tip>
                                        <TextBlock Text="{Binding Tooltip}" />
                                    </ToolTip.Tip>
                                </shapes:Ellipse>
                            </Canvas>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Canvas>
        </ScrollViewer>

        <Border Grid.Row="1"
                Background="#E3E3E3"
                BorderBrush="#B4B4B4"
                BorderThickness="1,1,0,0"
                Padding="10,12">
            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        HorizontalAlignment="Left">
                <TextBlock VerticalAlignment="Center"
                           Text="Weight layer:" />
                <ComboBox Width="58"
                          ItemsSource="{Binding WeightLayerOptions}"
                          SelectedItem="{Binding SelectedWeightLayer, Mode=TwoWay}" />
                <Button Content="Refresh"
                        Command="{Binding RefreshCommand}" />
                <Button Content="Dismiss"
                        Click="Dismiss_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
