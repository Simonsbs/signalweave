<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:SignalWeave.Desktop.ViewModels"
        mc:Ignorable="d"
        x:Class="SignalWeave.Desktop.Views.NetworkConfigWindow"
        x:DataType="vm:NetworkConfigDialogViewModel"
        Width="430"
        Height="560"
        CanResize="False"
        Background="#E1E1E1"
        Title="Network Configuration">

    <Design.DataContext>
        <vm:NetworkConfigDialogViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.config-panel">
            <Setter Property="Background" Value="#EEEEEE" />
            <Setter Property="BorderBrush" Value="#9DB3CD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,10,8,8" />
        </Style>
        <Style Selector="TextBlock.config-label">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#3E3E3E" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.dialog">
            <Setter Property="Width" Value="100" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="#DDE5EE" />
            <Setter Property="BorderBrush" Value="#9DB3CD" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TabControl.config-tabs">
            <Setter Property="Background" Value="#E1E1E1" />
        </Style>
        <Style Selector="TabItem.config-tab">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Slider.config-slider">
            <Setter Property="Width" Value="108" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style Selector="CheckBox.bias-toggle">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Styles>

    <Grid Margin="10"
          RowDefinitions="*,Auto">
        <TabControl Grid.Row="0"
                    Classes="config-tabs"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <TabItem Classes="config-tab"
                     Header="FeedForward Net">
                <Border Classes="config-panel">
                    <Grid ColumnDefinitions="140,*,36"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="16">
                        <TextBlock Grid.Column="2"
                                   Text="bias"
                                   HorizontalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#4A4A4A" />

                        <TextBlock Grid.Row="0"
                                   Classes="config-label"
                                   Text="Total no. of layers:" />
                        <StackPanel Grid.Row="0"
                                    Grid.Column="1"
                                    Spacing="2">
                            <Slider Classes="config-slider"
                                    Minimum="2"
                                    Maximum="4"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding FeedForwardLayersValue, Mode=TwoWay}" />
                            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto">
                                <TextBlock Text="2" />
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Center"
                                           Text="3" />
                                <TextBlock Grid.Column="4"
                                           HorizontalAlignment="Right"
                                           Text="4" />
                            </Grid>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Classes="config-label"
                                   Text="Input units:" />
                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Spacing="2">
                            <Slider Classes="config-slider"
                                    Minimum="1"
                                    Maximum="10"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding InputUnitsValue, Mode=TwoWay}" />
                            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto">
                                <TextBlock Text="1" />
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Center"
                                           Text="5" />
                                <TextBlock Grid.Column="4"
                                           HorizontalAlignment="Right"
                                           Text="10" />
                            </Grid>
                        </StackPanel>
                        <CheckBox Classes="bias-toggle"
                                  Grid.Row="1"
                                  Grid.Column="2"
                                  IsChecked="{Binding UseInputBias, Mode=TwoWay}" />

                        <TextBlock Grid.Row="2"
                                   Classes="config-label"
                                   Text="Layer 1:" />
                        <StackPanel Grid.Row="2"
                                    Grid.Column="1"
                                    Spacing="2"
                                    IsEnabled="{Binding IsFeedForwardFirstLayerEnabled}">
                            <Slider Classes="config-slider"
                                    Minimum="0"
                                    Maximum="10"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding HiddenUnitsValue, Mode=TwoWay}" />
                            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto">
                                <TextBlock Text="1" />
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Center"
                                           Text="5" />
                                <TextBlock Grid.Column="4"
                                           HorizontalAlignment="Right"
                                           Text="10" />
                            </Grid>
                        </StackPanel>
                        <CheckBox Classes="bias-toggle"
                                  Grid.Row="2"
                                  Grid.Column="2"
                                  IsEnabled="{Binding IsFeedForwardFirstLayerEnabled}"
                                  IsChecked="{Binding UseHiddenBias, Mode=TwoWay}" />

                        <TextBlock Grid.Row="3"
                                   Classes="config-label"
                                   IsEnabled="{Binding IsFeedForwardSecondLayerEnabled}"
                                   Text="Layer 2:" />
                        <StackPanel Grid.Row="3"
                                    Grid.Column="1"
                                    Spacing="2"
                                    IsEnabled="{Binding IsFeedForwardSecondLayerEnabled}">
                            <Slider Classes="config-slider"
                                    Minimum="1"
                                    Maximum="10"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding SecondHiddenUnitsValue, Mode=TwoWay}" />
                            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto">
                                <TextBlock Text="1" />
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Center"
                                           Text="5" />
                                <TextBlock Grid.Column="4"
                                           HorizontalAlignment="Right"
                                           Text="10" />
                            </Grid>
                        </StackPanel>
                        <CheckBox Classes="bias-toggle"
                                  Grid.Row="3"
                                  Grid.Column="2"
                                  IsEnabled="{Binding IsFeedForwardSecondLayerEnabled}"
                                  IsChecked="{Binding UseSecondHiddenBias, Mode=TwoWay}" />

                        <TextBlock Grid.Row="4"
                                   Classes="config-label"
                                   Text="Output units:" />
                        <StackPanel Grid.Row="4"
                                    Grid.Column="1"
                                    Spacing="2">
                            <Slider Classes="config-slider"
                                    Minimum="1"
                                    Maximum="10"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding OutputUnitsValue, Mode=TwoWay}" />
                            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto">
                                <TextBlock Text="1" />
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Center"
                                           Text="5" />
                                <TextBlock Grid.Column="4"
                                           HorizontalAlignment="Right"
                                           Text="10" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Classes="config-tab"
                     Header="SRN">
                <Border Classes="config-panel">
                    <Grid ColumnDefinitions="140,*,36"
                          RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="16">
                        <TextBlock Grid.Column="2"
                                   Text="bias"
                                   HorizontalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#4A4A4A" />

                        <TextBlock Classes="config-label"
                                   Text="Input units:" />
                        <StackPanel Grid.Column="1"
                                    Spacing="2">
                            <Slider Classes="config-slider"
                                    Minimum="1"
                                    Maximum="10"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding InputUnitsValue, Mode=TwoWay}" />
                            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto">
                                <TextBlock Text="1" />
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Center"
                                           Text="5" />
                                <TextBlock Grid.Column="4"
                                           HorizontalAlignment="Right"
                                           Text="10" />
                            </Grid>
                        </StackPanel>
                        <CheckBox Classes="bias-toggle"
                                  Grid.Column="2"
                                  IsChecked="{Binding UseInputBias, Mode=TwoWay}" />

                        <TextBlock Grid.Row="1"
                                   Classes="config-label"
                                   Text="Layer 1:" />
                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Spacing="2">
                            <Slider Classes="config-slider"
                                    Minimum="1"
                                    Maximum="10"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding HiddenUnitsValue, Mode=TwoWay}" />
                            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto">
                                <TextBlock Text="1" />
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Center"
                                           Text="5" />
                                <TextBlock Grid.Column="4"
                                           HorizontalAlignment="Right"
                                           Text="10" />
                            </Grid>
                        </StackPanel>
                        <CheckBox Classes="bias-toggle"
                                  Grid.Row="1"
                                  Grid.Column="2"
                                  IsChecked="{Binding UseHiddenBias, Mode=TwoWay}" />

                        <TextBlock Grid.Row="2"
                                   Classes="config-label"
                                   Text="Output units:" />
                        <StackPanel Grid.Row="2"
                                    Grid.Column="1"
                                    Spacing="2">
                            <Slider Classes="config-slider"
                                    Minimum="1"
                                    Maximum="10"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding OutputUnitsValue, Mode=TwoWay}" />
                            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto">
                                <TextBlock Text="1" />
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Center"
                                           Text="5" />
                                <TextBlock Grid.Column="4"
                                           HorizontalAlignment="Right"
                                           Text="10" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1"
                    Margin="0,10,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="18">
            <Button Classes="dialog" Content="OK" Click="Ok_Click" />
            <Button Classes="dialog" Content="Apply" Click="Apply_Click" />
            <Button Classes="dialog" Content="Cancel" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
