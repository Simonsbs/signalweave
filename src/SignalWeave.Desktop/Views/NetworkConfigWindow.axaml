<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:SignalWeave.Desktop.ViewModels"
        mc:Ignorable="d"
        x:Class="SignalWeave.Desktop.Views.NetworkConfigWindow"
        x:DataType="vm:NetworkConfigDialogViewModel"
        Width="430"
        Height="620"
        CanResize="False"
        Background="#E5E5E5"
        Title="Network Configuration">

    <Design.DataContext>
        <vm:NetworkConfigDialogViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.config-panel">
            <Setter Property="Background" Value="#F1F1F1" />
            <Setter Property="BorderBrush" Value="#A8B9CC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style Selector="TextBlock.config-label">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#3E3E3E" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.dialog">
            <Setter Property="Width" Value="96" />
            <Setter Property="Height" Value="38" />
        </Style>
    </Window.Styles>

    <Grid Margin="10"
          RowDefinitions="Auto,Auto,*,Auto,Auto">
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="12">
            <TextBlock Text="Network name"
                       VerticalAlignment="Center" />
            <TextBox Grid.Column="1"
                     Text="{Binding Name, Mode=TwoWay}" />
        </Grid>

        <TabControl Grid.Row="1"
                    Grid.RowSpan="2"
                    Margin="0,10,0,0"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <TabItem Header="FeedForward Net">
                <Border Classes="config-panel">
                    <Grid ColumnDefinitions="140,*,36"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="16">
                        <TextBlock Grid.Column="2"
                                   Text="bias"
                                   HorizontalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#4A4A4A" />

                        <TextBlock Grid.Row="0"
                                   Classes="config-label"
                                   Text="Total no. of layers:" />
                        <StackPanel Grid.Row="0"
                                    Grid.Column="1"
                                    Spacing="2">
                            <Slider Minimum="2"
                                    Maximum="4"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding FeedForwardLayersValue, Mode=TwoWay}" />
                            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto">
                                <TextBlock Text="2" />
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Center"
                                           Text="3" />
                                <TextBlock Grid.Column="4"
                                           HorizontalAlignment="Right"
                                           Text="4" />
                            </Grid>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Classes="config-label"
                                   Text="Input units:" />
                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Spacing="2">
                            <Slider Minimum="1"
                                    Maximum="10"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding InputUnitsValue, Mode=TwoWay}" />
                            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto">
                                <TextBlock Text="1" />
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Center"
                                           Text="5" />
                                <TextBlock Grid.Column="4"
                                           HorizontalAlignment="Right"
                                           Text="10" />
                            </Grid>
                        </StackPanel>
                        <CheckBox Grid.Row="1"
                                  Grid.Column="2"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding UseInputBias, Mode=TwoWay}" />

                        <TextBlock Grid.Row="2"
                                   Classes="config-label"
                                   Text="Layer 1:" />
                        <StackPanel Grid.Row="2"
                                    Grid.Column="1"
                                    Spacing="2">
                            <Slider Minimum="1"
                                    Maximum="10"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding HiddenUnitsValue, Mode=TwoWay}" />
                            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto">
                                <TextBlock Text="1" />
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Center"
                                           Text="5" />
                                <TextBlock Grid.Column="4"
                                           HorizontalAlignment="Right"
                                           Text="10" />
                            </Grid>
                        </StackPanel>
                        <CheckBox Grid.Row="2"
                                  Grid.Column="2"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding UseHiddenBias, Mode=TwoWay}" />

                        <TextBlock Grid.Row="3"
                                   Classes="config-label"
                                   Text="Layer 2:" />
                        <StackPanel Grid.Row="3"
                                    Grid.Column="1"
                                    Spacing="2"
                                    IsEnabled="{Binding IsFeedForwardSecondLayerEnabled}">
                            <Slider Minimum="1"
                                    Maximum="10"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding SecondHiddenUnitsValue, Mode=TwoWay}" />
                            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto">
                                <TextBlock Text="1" />
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Center"
                                           Text="5" />
                                <TextBlock Grid.Column="4"
                                           HorizontalAlignment="Right"
                                           Text="10" />
                            </Grid>
                        </StackPanel>
                        <CheckBox Grid.Row="3"
                                  Grid.Column="2"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsEnabled="{Binding IsFeedForwardSecondLayerEnabled}"
                                  IsChecked="{Binding UseSecondHiddenBias, Mode=TwoWay}" />

                        <TextBlock Grid.Row="4"
                                   Classes="config-label"
                                   Text="Output units:" />
                        <StackPanel Grid.Row="4"
                                    Grid.Column="1"
                                    Spacing="2">
                            <Slider Minimum="1"
                                    Maximum="10"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding OutputUnitsValue, Mode=TwoWay}" />
                            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto">
                                <TextBlock Text="1" />
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Center"
                                           Text="5" />
                                <TextBlock Grid.Column="4"
                                           HorizontalAlignment="Right"
                                           Text="10" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="SRN">
                <Border Classes="config-panel">
                    <Grid ColumnDefinitions="140,*,36"
                          RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="16">
                        <TextBlock Grid.Column="2"
                                   Text="bias"
                                   HorizontalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#4A4A4A" />

                        <TextBlock Classes="config-label"
                                   Text="Input units:" />
                        <StackPanel Grid.Column="1"
                                    Spacing="2">
                            <Slider Minimum="1"
                                    Maximum="10"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding InputUnitsValue, Mode=TwoWay}" />
                            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto">
                                <TextBlock Text="1" />
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Center"
                                           Text="5" />
                                <TextBlock Grid.Column="4"
                                           HorizontalAlignment="Right"
                                           Text="10" />
                            </Grid>
                        </StackPanel>
                        <CheckBox Grid.Column="2"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding UseInputBias, Mode=TwoWay}" />

                        <TextBlock Grid.Row="1"
                                   Classes="config-label"
                                   Text="Layer 1:" />
                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Spacing="2">
                            <Slider Minimum="1"
                                    Maximum="10"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding HiddenUnitsValue, Mode=TwoWay}" />
                            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto">
                                <TextBlock Text="1" />
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Center"
                                           Text="5" />
                                <TextBlock Grid.Column="4"
                                           HorizontalAlignment="Right"
                                           Text="10" />
                            </Grid>
                        </StackPanel>
                        <CheckBox Grid.Row="1"
                                  Grid.Column="2"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding UseHiddenBias, Mode=TwoWay}" />

                        <TextBlock Grid.Row="2"
                                   Classes="config-label"
                                   Text="Output units:" />
                        <StackPanel Grid.Row="2"
                                    Grid.Column="1"
                                    Spacing="2">
                            <Slider Minimum="1"
                                    Maximum="10"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding OutputUnitsValue, Mode=TwoWay}" />
                            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto">
                                <TextBlock Text="1" />
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Center"
                                           Text="5" />
                                <TextBlock Grid.Column="4"
                                           HorizontalAlignment="Right"
                                           Text="10" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3"
                Margin="0,12,0,12"
                Background="#F3F3F3"
                BorderBrush="#C8C8C8"
                BorderThickness="1"
                Padding="8">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#A33C2F"
                       TextWrapping="Wrap" />
        </Border>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10">
            <Button Classes="dialog" Content="OK" Click="Ok_Click" />
            <Button Classes="dialog" Content="Apply" Click="Apply_Click" />
            <Button Classes="dialog" Content="Cancel" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
