<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:SignalWeave.Desktop.ViewModels"
        mc:Ignorable="d"
        x:Class="SignalWeave.Desktop.Views.NetworkConfigWindow"
        x:DataType="vm:NetworkConfigDialogViewModel"
        Width="430"
        Height="560"
        CanResize="False"
        Background="#E1E1E1"
        Title="Network Configuration">

    <Design.DataContext>
        <vm:NetworkConfigDialogViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.config-panel">
            <Setter Property="Background" Value="#EEEEEE" />
            <Setter Property="BorderBrush" Value="#9DB3CD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,10,8,8" />
        </Style>
        <Style Selector="TextBlock.config-label">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#3E3E3E" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.dialog">
            <Setter Property="Width" Value="100" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="#DDE5EE" />
            <Setter Property="BorderBrush" Value="#9DB3CD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#2C3E50" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="TabControl.config-tabs">
            <Setter Property="Background" Value="#E1E1E1" />
        </Style>
        <Style Selector="TabItem.config-tab">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Slider.config-slider">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="CheckBox.bias-toggle">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.slider-value">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#4A4A4A" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.scale-label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#7A7A7A" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style Selector="Border.bias-separator">
            <Setter Property="Background" Value="#C0C0C0" />
            <Setter Property="Width" Value="1" />
        </Style>
    </Window.Styles>

    <Grid Margin="10"
          RowDefinitions="*,Auto">
        <TabControl Grid.Row="0"
                    Classes="config-tabs"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <TabItem Classes="config-tab"
                     Header="FeedForward Net">
                <Border Classes="config-panel">
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="140,*,12,1,12,36"
                              ColumnSpacing="0">
                            <TextBlock Grid.Column="0"
                                       Classes="config-label"
                                       Text="Total no. of layers:" />
                            <StackPanel Grid.Column="1"
                                        Spacing="12">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <Slider Classes="config-slider"
                                            Minimum="2"
                                            Maximum="4"
                                            TickFrequency="1"
                                            TickPlacement="BottomRight"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding FeedForwardLayersValue, Mode=TwoWay}" />
                                    <TextBlock Grid.Column="1"
                                               Classes="slider-value"
                                               Text="{Binding FeedForwardLayersValue}" />
                                </Grid>
                            </StackPanel>
                            <Border Grid.Column="3"
                                    Classes="bias-separator" />
                            <TextBlock Grid.Column="5"
                                       Text="bias"
                                       HorizontalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#4A4A4A" />
                        </Grid>

                        <Grid ColumnDefinitions="140,*,12,1,12,36"
                              ColumnSpacing="0">
                            <TextBlock Grid.Column="0"
                                       Classes="config-label"
                                       Text="Input units:" />
                            <StackPanel Grid.Column="1"
                                        Spacing="12">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <Slider Classes="config-slider"
                                            Minimum="1"
                                            Maximum="10"
                                            TickFrequency="1"
                                            TickPlacement="BottomRight"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding InputUnitsValue, Mode=TwoWay}" />
                                    <TextBlock Grid.Column="1"
                                               Classes="slider-value"
                                               Text="{Binding InputUnitsValue}" />
                                </Grid>
                            </StackPanel>
                            <Border Grid.Column="3"
                                    Classes="bias-separator" />
                            <CheckBox Grid.Column="5"
                                      Classes="bias-toggle"
                                      IsChecked="{Binding UseInputBias, Mode=TwoWay}" />
                        </Grid>

                        <Grid ColumnDefinitions="140,*,12,1,12,36"
                              ColumnSpacing="0">
                            <TextBlock Grid.Column="0"
                                       Classes="config-label"
                                       IsEnabled="{Binding IsFeedForwardFirstLayerEnabled}"
                                       Text="Layer 1:" />
                            <StackPanel Grid.Column="1"
                                        Spacing="12"
                                        IsEnabled="{Binding IsFeedForwardFirstLayerEnabled}">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <Slider Classes="config-slider"
                                            Minimum="0"
                                            Maximum="10"
                                            TickFrequency="1"
                                            TickPlacement="BottomRight"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding HiddenUnitsValue, Mode=TwoWay}" />
                                    <TextBlock Grid.Column="1"
                                               Classes="slider-value"
                                               Text="{Binding HiddenUnitsValue}" />
                                </Grid>
                            </StackPanel>
                            <Border Grid.Column="3"
                                    Classes="bias-separator" />
                            <CheckBox Grid.Column="5"
                                      Classes="bias-toggle"
                                      IsEnabled="{Binding IsFeedForwardFirstLayerEnabled}"
                                      IsChecked="{Binding UseHiddenBias, Mode=TwoWay}" />
                        </Grid>

                        <Grid ColumnDefinitions="140,*,12,1,12,36"
                              ColumnSpacing="0">
                            <TextBlock Grid.Column="0"
                                       Classes="config-label"
                                       IsEnabled="{Binding IsFeedForwardSecondLayerEnabled}"
                                       Text="Layer 2:" />
                            <StackPanel Grid.Column="1"
                                        Spacing="12"
                                        IsEnabled="{Binding IsFeedForwardSecondLayerEnabled}">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <Slider Classes="config-slider"
                                            Minimum="1"
                                            Maximum="10"
                                            TickFrequency="1"
                                            TickPlacement="BottomRight"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding SecondHiddenUnitsValue, Mode=TwoWay}" />
                                    <TextBlock Grid.Column="1"
                                               Classes="slider-value"
                                               Text="{Binding SecondHiddenUnitsValue}" />
                                </Grid>
                            </StackPanel>
                            <Border Grid.Column="3"
                                    Classes="bias-separator" />
                            <CheckBox Grid.Column="5"
                                      Classes="bias-toggle"
                                      IsEnabled="{Binding IsFeedForwardSecondLayerEnabled}"
                                      IsChecked="{Binding UseSecondHiddenBias, Mode=TwoWay}" />
                        </Grid>

                        <Grid ColumnDefinitions="140,*,12,1,12,36"
                              ColumnSpacing="0">
                            <TextBlock Grid.Column="0"
                                       Classes="config-label"
                                       Text="Output units:" />
                            <StackPanel Grid.Column="1"
                                        Spacing="12">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <Slider Classes="config-slider"
                                            Minimum="1"
                                            Maximum="10"
                                            TickFrequency="1"
                                            TickPlacement="BottomRight"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding OutputUnitsValue, Mode=TwoWay}" />
                                    <TextBlock Grid.Column="1"
                                               Classes="slider-value"
                                               Text="{Binding OutputUnitsValue}" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Classes="config-tab"
                     Header="SRN">
                <Border Classes="config-panel">
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="140,*,12,1,12,36"
                              ColumnSpacing="0">
                            <TextBlock Grid.Column="0"
                                       Classes="config-label"
                                       Text="Input units:" />
                            <StackPanel Grid.Column="1"
                                        Spacing="12">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <Slider Classes="config-slider"
                                            Minimum="1"
                                            Maximum="10"
                                            TickFrequency="1"
                                            TickPlacement="BottomRight"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding InputUnitsValue, Mode=TwoWay}" />
                                    <TextBlock Grid.Column="1"
                                               Classes="slider-value"
                                               Text="{Binding InputUnitsValue}" />
                                </Grid>
                            </StackPanel>
                            <Border Grid.Column="3"
                                    Classes="bias-separator" />
                            <TextBlock Grid.Column="5"
                                       Text="bias"
                                       HorizontalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#4A4A4A" />
                        </Grid>

                        <Grid ColumnDefinitions="140,*,12,1,12,36"
                              ColumnSpacing="0">
                            <TextBlock Grid.Column="0"
                                       Classes="config-label"
                                       Text="Layer 1:" />
                            <StackPanel Grid.Column="1"
                                        Spacing="12">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <Slider Classes="config-slider"
                                            Minimum="1"
                                            Maximum="10"
                                            TickFrequency="1"
                                            TickPlacement="BottomRight"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding HiddenUnitsValue, Mode=TwoWay}" />
                                    <TextBlock Grid.Column="1"
                                               Classes="slider-value"
                                               Text="{Binding HiddenUnitsValue}" />
                                </Grid>
                            </StackPanel>
                            <Border Grid.Column="3"
                                    Classes="bias-separator" />
                            <CheckBox Grid.Column="5"
                                      Classes="bias-toggle"
                                      IsChecked="{Binding UseHiddenBias, Mode=TwoWay}" />
                        </Grid>

                        <Grid ColumnDefinitions="140,*,12,1,12,36"
                              ColumnSpacing="0">
                            <TextBlock Grid.Column="0"
                                       Classes="config-label"
                                       Text="Output units:" />
                            <StackPanel Grid.Column="1"
                                        Spacing="12">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <Slider Classes="config-slider"
                                            Minimum="1"
                                            Maximum="10"
                                            TickFrequency="1"
                                            TickPlacement="BottomRight"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding OutputUnitsValue, Mode=TwoWay}" />
                                    <TextBlock Grid.Column="1"
                                               Classes="slider-value"
                                               Text="{Binding OutputUnitsValue}" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1"
                    Margin="0,10,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="18">
            <Button Classes="dialog" Content="OK" Click="Ok_Click" />
            <Button Classes="dialog" Content="Apply" Click="Apply_Click" />
            <Button Classes="dialog" Content="Cancel" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
